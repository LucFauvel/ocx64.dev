---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const projects = [
  {
    name: 'Scaddle',
    tagline: 'An AI-powered OpenSCAD IDE',
    href: 'https://scaddle.app',
    repo: 'https://github.com/LucFauvel/scaddle',
    image: '/scaddle.png',
    description:
      'A browser-based OpenSCAD IDE with real-time 3D visualization. Write OpenSCAD by hand in a Monaco editor, or describe what you want in plain English and let Gemini generate the code for you. Models compile in-browser via WebAssembly and render live with Three.js, then export straight to STL for printing.',
    tags: ['Angular', 'Three.js', 'Bun', 'tRPC', 'WASM', 'Gemini'],
  },
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Projects | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Things I'm building</h1>
			<p>
				A few projects I've poured time into. Code, hardware, and the odd weekend rabbit hole.
			</p>
			<ul class="projects">
				{
					projects.map((project) => (
						<li data-reveal>
							<div class="card-head">
								<h2 class="name">
									<a href={project.href} target="_blank" rel="noopener">{project.name}</a>
								</h2>
								<span class="tagline handwritten">{project.tagline}</span>
							</div>
							{project.image && (
								<a class="shot" href={project.href} target="_blank" rel="noopener">
									<img src={project.image} alt={`Screenshot of ${project.name}`} loading="lazy" />
								</a>
							)}
							<p class="desc">{project.description}</p>
							<ul class="tags">
								{project.tags.map((tag) => <li>{tag}</li>)}
							</ul>
							<div class="links">
								<a href={project.href} target="_blank" rel="noopener">Live site</a>
								<a href={project.repo} target="_blank" rel="noopener">Source</a>
							</div>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
<style>
	.projects {
		list-style: none;
		margin: 2rem 0 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
	}
	/* each project sits on a sheet of paper tacked to the page */
	.projects > li {
		position: relative;
		background: var(--cream);
		padding: 1.4rem 1.6rem 1.6rem;
		border: var(--border-light);
		box-shadow: 4px 5px 0 rgba(var(--black), 0.08);
		transform: rotate(-1deg);
		transition: transform 0.25s ease, box-shadow 0.25s ease;
	}
	.projects > li:nth-child(2n) {
		transform: rotate(1.2deg);
	}
	/* washi tape strip in highlighter yellow */
	.projects > li::before {
		content: '';
		position: absolute;
		top: -13px;
		left: 50%;
		width: 90px;
		height: 26px;
		transform: translateX(-50%) rotate(-3deg);
		background: rgba(var(--highlighter), 0.4);
		border-left: 1px solid rgba(var(--black), 0.06);
		border-right: 1px solid rgba(var(--black), 0.06);
		box-shadow: 0 1px 2px rgba(var(--black), 0.08);
		z-index: 3;
	}
	.projects > li:hover {
		transform: rotate(0deg) translateY(-5px);
		box-shadow: 7px 9px 0 rgba(var(--black), 0.12);
	}

	.card-head {
		display: flex;
		align-items: baseline;
		flex-wrap: wrap;
		gap: 0.3em 0.8em;
		margin-bottom: 0.6rem;
	}
	.name {
		margin: 0;
		line-height: 1;
	}
	.name a {
		color: rgb(var(--black));
		text-decoration: none;
	}
	.name a:hover {
		color: rgb(var(--accent));
	}
	.tagline {
		color: rgb(var(--gray-dark));
		font-size: 1.4em;
		line-height: 1;
	}
	/* app screenshot, framed like the blog hero images */
	.shot {
		display: block;
		margin: 0 0 1.1rem;
		line-height: 0;
	}
	.shot img {
		display: block;
		width: 100%;
		border: var(--border-light);
		transition: border-color 0.2s ease;
	}
	.shot:hover img {
		border-color: rgb(var(--black));
	}
	.desc {
		margin: 0 0 1rem;
	}

	.tags {
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin: 0 0 1.1rem;
		padding: 0;
	}
	.tags li {
		font-size: 0.8em;
		padding: 0.15em 0.6em;
		border: var(--border-light);
		background: rgba(var(--highlighter), 0.18);
		color: rgb(var(--gray-dark));
	}

	.links {
		display: flex;
		gap: 1.2rem;
	}

	/* scroll-reveal preserving each sheet's resting tilt */
	.projects > li[data-reveal] {
		opacity: 0;
		transform: translateY(18px) rotate(-1deg);
		transition: opacity 0.6s ease, transform 0.35s ease, box-shadow 0.25s ease;
	}
	.projects > li[data-reveal]:nth-child(2n) {
		transform: translateY(18px) rotate(1.2deg);
	}
	.projects > li[data-reveal].in-view {
		opacity: 1;
	}

	@media (prefers-reduced-motion: reduce) {
		.projects > li,
		.projects > li[data-reveal] {
			transition: none;
			opacity: 1;
		}
	}
</style>
