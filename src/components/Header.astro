---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
    <div class="home-fire-wrap">
    <button class="home-fire" type="button" aria-label="Add a log to the fire">
      <svg class="campfire" viewBox="0 0 64 64" aria-hidden="true">
        <g stroke-linecap="round">
          <line x1="13" y1="57" x2="51" y2="48" stroke="#6b431f" stroke-width="6"/>
          <line x1="51" y1="57" x2="13" y2="48" stroke="#855735" stroke-width="6"/>
        </g>
        <g class="flames">
          <path d="M32 7 C 41 20 45 25 45 35 C 45 46 39 53 32 53 C 25 53 19 46 19 36 C 19 30 22 27 25 31 C 26 22 29 15 32 7 Z" fill="#e8732a"/>
          <path d="M33 24 C 38 30 39 33 39 39 C 39 45 35 49 32 49 C 28 49 26 45 26 40 C 26 36 28 34 30 36 C 30 31 31 28 33 24 Z" fill="#f2b134"/>
        </g>
        <line class="new-log" x1="14" y1="53" x2="50" y2="50" stroke="#7a4a22" stroke-width="6" stroke-linecap="round"/>
      </svg>
    </button>
      <a class="go-home handwritten" href="/">trying to get home?</a>
    </div>
		<div class="internal-links">
			<HeaderLink href="/">Me</HeaderLink>
			<HeaderLink href="/projects">Projects</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/friends">Friends</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://x.com/ocx64" target="_blank">
				<span class="sr-only">Follow me on X</span>
				X/Twitter
      </a>
			<a href="https://bsky.app/profile/ocx64.dev" target="_blank">
				<span class="sr-only">Follow me on Bluesky</span>
                Bluesky
			<a href="https://github.com/LucFauvel" target="_blank">
				<span class="sr-only">Go to my GitHub profile</span>
				GitHub
			</a>
		</div>
	</nav>
</header>
<style>
	header {
    margin: 0;
    padding: 0 1em;
    background: var(--cream);
    border-bottom: var(--border);
  }
  h2 {
      margin: 0;
      font-size: 1em;
  }
  h2 a,
  h2 a.active {
      text-decoration: none;
  }
  nav {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
  }
  /* keep the fire on the left and socials on the right, links dead-center */
  nav > .home-fire-wrap {
      justify-self: start;
  }
  nav > .internal-links {
      justify-self: center;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      column-gap: 0.25em;
  }
  nav > .social-links {
      justify-self: end;
  }
  nav a {
      padding: 1em 0.5em;
      color: rgb(var(--gray-dark));
      border-bottom: 2px solid transparent;
      text-decoration: none;
  }
  nav a:hover {
      color: rgb(var(--black));
  }
  nav a.active {
      text-decoration: none;
      border-bottom-color: transparent;
      color: rgb(var(--black));
      background-image: linear-gradient(rgba(var(--highlighter), 0.6), rgba(var(--highlighter), 0.6));
      background-repeat: no-repeat;
      background-position: 0 72%;
      background-size: 100% 0.5em;
  }
  .social-links,
  .social-links a {
      display: flex;
  }
  .home-fire-wrap {
    position: relative;
    display: inline-flex;
    align-items: center;
  }
  /* a little hint that floats out beside the fire, pointing the way home */
  .home-fire-wrap .go-home {
    position: absolute;
    left: 100%;
    top: 50%;
    margin-left: 0.4em;
    padding: 0.15em 0.5em;
    white-space: nowrap;
    font-size: 1.3em;
    line-height: 1;
    color: rgb(var(--terracotta));
    text-decoration: none;
    background: var(--cream);
    border-radius: 0.3em;
    box-shadow: 2px 3px 0 rgba(var(--black), 0.1);
    z-index: 5;
    transform: translateY(-50%) rotate(-4deg) translateX(-6px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  .home-fire-wrap.show-hint .go-home {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(-50%) rotate(-4deg) translateX(0);
  }
  .home-fire-wrap .go-home:hover {
    color: rgb(var(--terracotta));
    text-decoration: underline;
    text-decoration-style: wavy;
  }
  @media (prefers-reduced-motion: reduce) {
    .home-fire-wrap .go-home {
      transition: none;
    }
  }
  .home-fire {
    padding: 0 !important;
    display: inline-flex;
    align-items: center;
    line-height: 0;
    background: none;
    border: none;
    cursor: pointer;
  }
  .campfire {
    height: 46px;
    width: 46px;
    display: block;
    /* let a thrown log fly in from beyond the icon's box */
    overflow: visible;
  }
  .campfire .flames {
    transform-origin: 32px 50px;
    animation: flicker 1.9s ease-in-out infinite;
  }
  /* a fresh log, hidden until you feed the fire */
  .campfire .new-log {
    opacity: 0;
    transform-box: view-box;
    transform-origin: 32px 52px;
  }
  /* click: log drops in, flames flare up, then it settles into the blaze */
  .home-fire.adding .new-log {
    animation: throw-log 1.1s ease forwards;
  }
  .home-fire.adding .flames {
    animation: flare 1.1s ease;
  }
  /* tossed in from the left edge with a tumble, lands and settles into the pile */
  @keyframes throw-log {
    0% {
      transform: translate(-90px, -20px) rotate(-320deg);
      opacity: 0;
    }
    12% {
      opacity: 1;
    }
    45% {
      transform: translate(0, 0) rotate(0deg);
    }
    56% {
      transform: translate(3px, -3px) rotate(7deg);
    }
    70% {
      transform: translate(0, 0) rotate(0deg);
      opacity: 1;
    }
    100% {
      transform: translate(0, 0) rotate(0deg);
      opacity: 0;
    }
  }
  @keyframes flare {
    0%, 22% {
      transform: scaleY(1) scaleX(1);
    }
    45% {
      transform: scaleY(1.38) scaleX(1.14);
    }
    70% {
      transform: scaleY(1.14) scaleX(1.05);
    }
    100% {
      transform: scaleY(1) scaleX(1);
    }
  }
  @keyframes flicker {
    0%, 100% {
      transform: scaleY(1) scaleX(1);
      opacity: 1;
    }
    30% {
      transform: scaleY(1.07) scaleX(0.96);
      opacity: 0.95;
    }
    55% {
      transform: scaleY(0.95) scaleX(1.04);
      opacity: 0.88;
    }
    80% {
      transform: scaleY(1.04) scaleX(0.98);
      opacity: 0.97;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .campfire .flames {
      animation: none;
    }
    .home-fire.adding .new-log,
    .home-fire.adding .flames {
      animation: none;
    }
  }
  @media (max-width: 830px) {
      .social-links {
          display: none;
      }
  }
  @media (max-width: 600px) {
      nav {
          grid-template-columns: 1fr;
          row-gap: 0.15em;
          padding-block: 0.5em;
      }
      nav > .home-fire-wrap {
          justify-self: start;
      }
      nav > .internal-links {
          justify-self: stretch;
      }
      nav a {
          padding: 0.4em 0.5em;
          font-size: 0.95em;
      }
  }
</style>
<script is:inline>
  (() => {
    const fire = document.querySelector('.home-fire');
    const wrap = document.querySelector('.home-fire-wrap');
    if (!fire || !wrap) return;
    let busy = false;
    let hintTimer;
    fire.addEventListener('click', () => {
      // reveal the way-home hint and let it linger
      wrap.classList.add('show-hint');
      window.clearTimeout(hintTimer);
      hintTimer = window.setTimeout(() => wrap.classList.remove('show-hint'), 3500);
      // feed the fire (one log at a time)
      if (busy) return;
      busy = true;
      fire.classList.add('adding');
      window.setTimeout(() => {
        fire.classList.remove('adding');
        busy = false;
      }, 1100);
    });
  })();
</script>
