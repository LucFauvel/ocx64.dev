---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
    <a class="home-fire" href="/" aria-label="Home">
      <svg class="campfire" viewBox="0 0 64 64" aria-hidden="true">
        <g stroke-linecap="round">
          <line x1="13" y1="57" x2="51" y2="48" stroke="#6b431f" stroke-width="6"/>
          <line x1="51" y1="57" x2="13" y2="48" stroke="#855735" stroke-width="6"/>
        </g>
        <g class="flames">
          <path d="M32 7 C 41 20 45 25 45 35 C 45 46 39 53 32 53 C 25 53 19 46 19 36 C 19 30 22 27 25 31 C 26 22 29 15 32 7 Z" fill="#e8732a"/>
          <path d="M33 24 C 38 30 39 33 39 39 C 39 45 35 49 32 49 C 28 49 26 45 26 40 C 26 36 28 34 30 36 C 30 31 31 28 33 24 Z" fill="#f2b134"/>
        </g>
      </svg>
    </a>
		<div class="internal-links">
			<HeaderLink href="/">Me</HeaderLink>
			<HeaderLink href="/projects">Projects</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/friends">Friends</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://x.com/ocx64" target="_blank">
				<span class="sr-only">Follow me on X</span>
				X/Twitter
      </a>
			<a href="https://bsky.app/profile/ocx64.dev" target="_blank">
				<span class="sr-only">Follow me on Bluesky</span>
                Bluesky
			<a href="https://github.com/LucFauvel" target="_blank">
				<span class="sr-only">Go to my GitHub profile</span>
				GitHub
			</a>
		</div>
	</nav>
</header>
<style>
	header {
    margin: 0;
    padding: 0 1em;
    background: var(--cream);
    border-bottom: var(--border);
  }
  h2 {
      margin: 0;
      font-size: 1em;
  }
  h2 a,
  h2 a.active {
      text-decoration: none;
  }
  nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
  }
  nav a {
      padding: 1em 0.5em;
      color: rgb(var(--gray-dark));
      border-bottom: 2px solid transparent;
      text-decoration: none;
  }
  nav a:hover {
      color: rgb(var(--black));
  }
  nav a.active {
      text-decoration: none;
      border-bottom-color: transparent;
      color: rgb(var(--black));
      background-image: linear-gradient(rgba(var(--highlighter), 0.6), rgba(var(--highlighter), 0.6));
      background-repeat: no-repeat;
      background-position: 0 72%;
      background-size: 100% 0.5em;
  }
  .social-links,
  .social-links a {
      display: flex;
  }
  .home-fire {
    padding: 0 !important;
    display: inline-flex;
    align-items: center;
    line-height: 0;
  }
  .campfire {
    height: 46px;
    width: 46px;
    display: block;
  }
  .campfire .flames {
    transform-origin: 32px 50px;
    animation: flicker 1.9s ease-in-out infinite;
  }
  @keyframes flicker {
    0%, 100% {
      transform: scaleY(1) scaleX(1);
      opacity: 1;
    }
    30% {
      transform: scaleY(1.07) scaleX(0.96);
      opacity: 0.95;
    }
    55% {
      transform: scaleY(0.95) scaleX(1.04);
      opacity: 0.88;
    }
    80% {
      transform: scaleY(1.04) scaleX(0.98);
      opacity: 0.97;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .campfire .flames {
      animation: none;
    }
  }
  @media (max-width: 720px) {
      .social-links {
          display: none;
      }
  }
</style>
